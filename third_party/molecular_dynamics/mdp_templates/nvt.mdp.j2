; NVT equilibration — generated from template
define                  = -DPOSRES
integrator              = md
dt                      = {{ dt }}
nsteps                  = {{ nsteps }}
nstxtcout               = 0
nstvout                 = 0
nstfout                 = 0
nstcalcenergy           = 100
nstenergy               = 1000
nstlog                  = 1000
;
cutoff-scheme           = Verlet
nstlist                 = 20
rlist                   = 1.2
vdwtype                 = Cut-off
vdw-modifier            = Force-switch
rvdw_switch             = 1.0
rvdw                    = 1.2
coulombtype             = pme
rcoulomb                = 1.2
;
tcoupl                  = Nose-Hoover
tc_grps                 = Protein Non-Protein
tau_t                   = 1.0 1.0
ref_t                   = {{ temperature }} {{ temperature }}
;
constraints             = h-bonds
constraint_algorithm    = LINCS
;
gen-vel                 = yes
gen-temp                = {{ temperature }}
gen-seed                = -1
